<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Statiq.Web" Version="1.0.0-beta.60" />
  </ItemGroup>

  <!-- Copy SharpScss's platform-specific libsass native binary next to the exe.
       dotnet run does not flatten runtimes/<rid>/native/ automatically; without this
       P/Invoke cannot find libsass when the working directory is the project root. -->
  <Target Name="CopyNativeSass" AfterTargets="Build">
    <ItemGroup>
      <_NativeSass Include="$(OutputPath)runtimes\win-x64\native\libsass.dll" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
      <_NativeSass Include="$(OutputPath)runtimes\linux-x64\native\libsass.so"  Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
      <_NativeSass Include="$(OutputPath)runtimes\osx-x64\native\libsass.dylib" Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
    </ItemGroup>
    <Copy SourceFiles="@(_NativeSass)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
  </Target>

</Project>
