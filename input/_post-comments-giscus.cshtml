@using System.Text.Json
@{
  string repoNameJson = JsonSerializer.Serialize(Document.GetString("GiscusRepoName"));
  string repoIdJson = JsonSerializer.Serialize(Document.GetString("GiscusRepoId"));
  string categoryIdJson = JsonSerializer.Serialize(Document.GetString("GiscusCategoryId"));
}
<div class="col-12 terminal-comments">
  <div id="giscus-container"></div>
</div>
<script>
  (function () {
    var container = document.getElementById('giscus-container');

    if (!container) {
      console.error('Unable to render comments because the Giscus container is missing.');
      return;
    }

    var theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark_dimmed';
    var script = document.createElement('script');

    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', @Html.Raw(repoNameJson));
    script.setAttribute('data-repo-id', @Html.Raw(repoIdJson));
    script.setAttribute('data-category-id', @Html.Raw(categoryIdJson));
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'top');
    script.setAttribute('data-theme', theme);
    script.setAttribute('data-lang', 'en');
    script.setAttribute('data-loading', 'lazy');
    script.setAttribute('crossorigin', 'anonymous');
    script.async = true;
    container.appendChild(script);
  })();
</script>
